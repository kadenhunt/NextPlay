# Copy to .env locally. Vite only exposes vars prefixed with VITE_.

# Production build: comma-separated emails allowed to see Dev mode. Empty = none in prod.
# In npm run dev, Dev mode is available without this list.
# VITE_NEXTPLAY_DEV_OWNER_EMAILS=you@example.com,other@example.com

# Transitional HTTP adapter config.
# Keep mock mode enabled until more backend endpoints are ready.
VITE_API_BASE_URL=http://localhost:4000
# Set to false to enable HTTP only for supported seam functions:
# getPlayers, getPlayerById, getMatchups, getStandings
VITE_USE_MOCK_API=true
